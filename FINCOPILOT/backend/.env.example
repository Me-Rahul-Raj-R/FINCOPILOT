# Copy this file to .env and fill in real values before running.

# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Auth
# Generate a real secret with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Admin account
# - In PERSISTENT MODE (MySQL): set these, then run `npm run seed:admin`.
# - In DEMO MODE (no DB_HOST below): the server seeds an admin with these
#   credentials automatically on every boot - check the startup logs.
ADMIN_EMAIL=admin@fincopilot.local
ADMIN_PASSWORD=Admin@12345

# MySQL connection.
# Leave DB_HOST BLANK to run FinCopilot in DEMO MODE, which uses a
# built-in in-memory data store instead of MySQL (zero setup, resets on
# restart). See the README's "Connect MySQL Workbench" section for the
# full step-by-step setup.
DB_HOST=
DB_PORT=3306
DB_NAME=fincopilot
DB_USER=fincopilot_user
DB_PASSWORD=
