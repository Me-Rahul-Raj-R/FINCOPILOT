{
  "name": "fincopilot-backend",
  "version": "2.1.0",
  "description": "FinCopilot AI banking risk, assistance & payments platform",
  "main": "server.js",
  "type": "commonjs",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "start":        "node server.js",
    "dev":          "node --watch server.js",
    "cluster":      "pm2 start ecosystem.config.js --env production",
    "seed:admin":   "node data/seedAdmin.js",
    "db:setup":     "node scripts/setup_db_local.js",
    "build:full":   "node ../scripts/build.js"
  },
  "dependencies": {
    "bcryptjs":         "^2.4.3",
    "compression":      "^1.7.4",
    "cors":             "^2.8.5",
    "dotenv":           "^16.4.5",
    "express":          "^4.19.2",
    "express-rate-limit":"^7.4.0",
    "helmet":           "^7.1.0",
    "jsonwebtoken":     "^9.0.2",
    "morgan":           "^1.10.0",
    "mysql2":           "^3.11.0",
    "sequelize":        "^6.37.3"
  }
}
